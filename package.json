{
  "name": "marketplace-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npm run db:generate --workspace=@marketplace/api",
    "db:migrate": "npm run db:migrate --workspace=@marketplace/api",
    "db:seed": "npm run db:seed --workspace=@marketplace/api",
    "test": "npm run test --workspace=@marketplace/api"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-safe-area-context": "5.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.8.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  }
}